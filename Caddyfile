{
    email {$ACME_EMAIL}
}

{$APP_SITE_ADDRESS} {
    encode zstd gzip

    # El navegador consume /api/v1 y Caddy lo envía al contenedor Spring Boot.
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Se publica únicamente el health check para validar despliegues.
    handle /actuator/health* {
        reverse_proxy backend:8080
    }

    # APK instalable para el banner de escritorio.
    @androidApk path /downloads/*.apk
    header @androidApk {
        Content-Type application/vnd.android.package-archive
        Content-Disposition "attachment; filename=sistema-electoral.apk"
        Cache-Control "no-cache, no-store, must-revalidate"
    }

    # Angular SPA: cualquier ruta que no sea un archivo vuelve a index.html.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    header {
        -Server
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    @assets path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2
    header @assets Cache-Control "public, max-age=31536000, immutable"
    header /index.html Cache-Control "no-store"
}
